# Local only. Railway and Render provide PORT automatically.
PORT=3000

# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:5501,http://127.0.0.1:5501,https://your-user.github.io

# Optional JSON persistence path.
# For persistent production storage, point this at a mounted volume or disk.
# Render free Web Services do not support persistent disks, so this file resets on redeploy/restart/spin-down.
DATA_FILE=./data/app-data.json
